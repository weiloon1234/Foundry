# Auto normalize line endings
* text=auto

# Rust source — enforce LF
*.rs text eol=lf
*.toml text eol=lf
*.md text eol=lf

# Shell scripts
*.sh text eol=lf
Makefile text eol=lf

# Windows scripts
*.bat text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary

# Lock files — treat as generated but keep diffable
Cargo.lock linguist-generated
